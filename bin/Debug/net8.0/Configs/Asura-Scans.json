  "QueryData": {
    "TitleSelector": [
      {
        "Query": "//h1[contains(@class, 'entry-title')]",
        "Type": "Single",
        "DataFrom": "InnerText"
      }
    ],
    "DescriptionSelector": [
      {
        "Query": "//div[@class='entry-content entry-content-single']//p",
        "Type": "Single",
        "DataFrom": "InnerText"
      }
    ],
    "CoverSelector": [
      {
        "Query": "//div[@itemprop='image']//img",
        "Type": "Single",
        "DataFrom": "DataSrc"
      }
    ],
    "StatusSelector": [
      {
        "Query": "(//div[@class='status-value'])[1]",
        "Type": "Single",
        "DataFrom": "InnerText"
      }
    ],
    "TypeSelector": [
      {
        "Query": "//tbody/tr[1]/td[2]",
        "Type": "Single",
        "DataFrom": "InnerText"
      }
    ],
    "AuthorSelector": [
      {
        "Query": "//tbody/tr[3]/td[2]",
        "Type": "Single",
        "DataFrom": "InnerText"
      }
    ],
    "RatingSelector": [
      {
        "Query": "",
        "Type": "None",
        "DataFrom": "None"
      }
    ],
    "GenreSelector": [
      {
        "Query": "//div[@class='seriestuheader']//a",
        "Type": "Multi",
        "DataFrom": "InnerText"
      }
    ],
    "ChapterLinksSelector": [
      {
        "Query": "//div[@id='chapterlist']//a",
        "Type": "Multi",
        "DataFrom": "Href"
      }
    ],
    "ChapterTitlesSelector": [
      {
        "Query": "(//div[@id='chapterlist'])//span[@class='chapternum']",
        "Type": "Multi",
        "DataFrom": "InnerText"
      }
    ],
    "ChapterContentsSelector": [
      {
        "Query": "(//div[@id='readerarea'])//img",
        "Type": "Multi",
        "DataFrom": "DataSrc"
      }
    ]
  },
