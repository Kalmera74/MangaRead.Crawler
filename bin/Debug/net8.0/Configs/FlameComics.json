{
  "SiteType": "Static",
  "RootUrl": "https://flamecomics.me",
  "ChapterRootUrl": "https://flamecomics.me/series/",
  "QueryData": {
    "TitleSelector": [
      {
        "Query": "//h1[contains(@class, 'entry-title')]",
        "Type": "Single",
        "DataFrom": "InnerText"
      }
    ],
    "DescriptionSelector": [
      {
        "Query": "//div[contains(@class, 'entry-content entry-content-single')]/p[1]",
        "Type": "Single",
        "DataFrom": "InnerText"
      }
    ],
    "CoverSelector": [
      {
        "Query": "//div[contains(@class, 'thumb')]//img",
        "Type": "Single",
        "DataFrom": "Src"
      }
    ],
    "StatusSelector": [
      {
        "Query": "//div[contains(@class, 'status')]//i",
        "Type": "Single",
        "DataFrom": "InnerText"
      }
    ],
    "TypeSelector": [
      {
        "Query": "//div[contains(@class, 'imptdt')][1]//i",
        "Type": "Single",
        "DataFrom": "InnerText"
      }
    ],
    "AuthorSelector": [
      {
        "Query": "//div[contains(@class, 'imptdt')][4]//i",
        "Type": "Single",
        "DataFrom": "InnerText"
      }
    ],
    "RatingSelector": [
      {
        "Query": "",
        "Type": "None",
        "DataFrom": "None"
      }
    ],
    "GenreSelector": [
      {
        "Query": "//div[contains(@class, 'genres-container')]//a",
        "Type": "Multi",
        "DataFrom": "InnerText"
      }
    ],
    "ChapterLinksSelector": [
      {
        "Query": "//div[@id='chapterlist']//a",
        "Type": "Multi",
        "DataFrom": "Href"
      }
    ],
    "ChapterTitlesSelector": [
      {
        "Query": "//div[@id='chapterlist']//span[contains(@class, 'chapternum')]",
        "Type": "Multi",
        "DataFrom": "InnerText"
      }
    ],
    "ChapterContentsSelector": [
      {
        "Query": "//div[@id='readerarea']//img",
        "Type": "Multi",
        "DataFrom": "Src"
      }
    ]
  },
  "MangaPages": []
}
