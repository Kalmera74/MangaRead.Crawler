{
  "SiteType": "Static",
  "RootUrl": "https://mangabuddy.com/",
  "ChapterRootUrl": "https://mangabuddy.com/",
  "QueryData": {
    "TitleSelector": [
      {
        "Query": "(//h1)[1]",
        "Type": "Single",
        "DataFrom": "InnerText"
      }
    ],
    "DescriptionSelector": [
      {
        "Query": "(//p[@class='content'])[1]",
        "Type": "Single",
        "DataFrom": "InnerText"
      }
    ],
    "CoverSelector": [
      {
        "Query": "//div[@class='img-cover']//img",
        "Type": "Single",
        "DataFrom": "Src"
      }
    ],
    "StatusSelector": [
      {
        "Query": "(//span)[11]",
        "Type": "Single",
        "DataFrom": "InnerText"
      }
    ],
    "TypeSelector": [
      {
        "Query": "",
        "Type": "None",
        "DataFrom": "None"
      }
    ],
    "AuthorSelector": [
      {
        "Query": "(//span)[10]",
        "Type": "Single",
        "DataFrom": "InnerText"
      }
    ],
    "RatingSelector": [
      {
        "Query": "",
        "Type": "None",
        "DataFrom": "None"
      }
    ],
    "GenreSelector": [
      {
        "Query": "(//p)[3]//a",
        "Type": "Multi",
        "DataFrom": "InnerText"
      }
    ],
    "ChapterLinksSelector": [
      {
        "Query": "//ul[@id='chapter-list']//a",
        "Type": "Multi",
        "DataFrom": "Href"
      }
    ],
    "ChapterTitlesSelector": [
      {
        "Query": "//ul[@id='chapter-list']//strong",
        "Type": "Multi",
        "DataFrom": "InnerText"
      }
    ],
    "ChapterContentsSelector": [
      {
        "Query": "//div[@id='chapter-images']//img",
        "Type": "Multi",
        "DataFrom": "Src"
      }
    ]
  },
  "MangaPages": []
}
