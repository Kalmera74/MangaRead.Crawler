{
  "SiteType": "Static",
  "RootUrl": "https://asurascanslation.com/",
  "ChapterRootUrl": "https://asurascanslation.com/manga/",
  "QueryData": {
    "TitleSelector": [
      {
        "Query": "//h1[@itemprop='name']",
        "Type": "Single",
        "DataFrom": "InnerText"
      }
    ],
    "DescriptionSelector": [
      {
        "Query": "//div[@itemprop='description']//p",
        "Type": "Single",
        "DataFrom": "InnerText"
      }
    ],
    "CoverSelector": [
      {
        "Query": "//img[@title]",
        "Type": "Single",
        "DataFrom": "Src"
      }
    ],
    "StatusSelector": [
      {
        "Query": "//div[@class='tsinfo bixbox']//div[1]//i[1]",
        "Type": "Single",
        "DataFrom": "InnerText"
      }
    ],
    "TypeSelector": [
      {
        "Query": "(//div[@class='imptdt'])[2]//a",
        "Type": "Single",
        "DataFrom": "InnerText"
      }
    ],
    "AuthorSelector": [
      {
        "Query": "//div[4]//i[1]",
        "Type": "Single",
        "DataFrom": "InnerText"
      }
    ],
    "RatingSelector": [
      {
        "Query": "",
        "Type": "None",
        "DataFrom": "None"
      }
    ],
    "GenreSelector": [
      {
        "Query": "(//span[@class='mgen'])[1]//a",
        "Type": "Multi",
        "DataFrom": "InnerText"
      }
    ],
    "ChapterLinksSelector": [
      {
        "Query": "//div[@id='chapterlist']//ul//a",
        "Type": "Multi",
        "DataFrom": "Href"
      }
    ],
    "ChapterTitlesSelector": [
      {
        "Query": "//div[@id='chapterlist']//ul//span[1]",
        "Type": "Multi",
        "DataFrom": "InnerText"
      }
    ],
    "ChapterContentsSelector": [
      {
        "Query": "(//div[@id='readerarea'])//img",
        "Type": "Multi",
        "DataFrom": "Src"
      }
    ]
  },
  "MangaPages": []
}
